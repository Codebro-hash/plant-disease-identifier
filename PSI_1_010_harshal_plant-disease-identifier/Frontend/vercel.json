{
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://plant-disease-identifier-3bxa.onrender.com/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://plant-disease-identifier-3bxa.onrender.com/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}