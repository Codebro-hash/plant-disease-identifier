VITE_FIREBASE_API_KEY=your_key
VITE_FIREBASE_AUTH_DOMAIN=your_domain
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Preferred for Vercel (proxy mode):
# - Do NOT set VITE_BACKEND_URL.
# - Vercel will forward /api/* and /uploads/* to your Render backend via vercel.json.
# VITE_API_BASE_URL=/api

# Optional (direct backend mode, e.g. local dev or non-proxied hosting):
# VITE_BACKEND_URL=https://plant-disease-identifier-3bxa.onrender.com
# VITE_ASSET_BASE_URL=https://plant-disease-identifier-3bxa.onrender.com
